# Copy to .env.local and fill in. Only VITE_-prefixed variables reach the bundle, and their
# values are COMPILED INTO the published JavaScript. Never put a secret here.

COMPOSE_PROJECT_NAME=task-manager

# Base URL of the backend API, baked in at build time.
# Leave empty to send same-origin relative requests (/api/...), which is what the Vite dev
# server proxies and what a reverse proxy in front of nginx would handle.
VITE_API_URL=

# Dev-server proxy target for /api when VITE_API_URL is empty. Defaults to http://localhost:80.
# VITE_DEV_PROXY_TARGET=http://localhost:80
